{% extends "base.html" %}

{% block title %}Part View - {{ part['part_number'] }}{% endblock %}

{% block content %}
    <div class="d-flex justify-content-between align-items-center">
        <h1>Part Details</h1>
        <div>
            <a href="{{ url_for('edit_part', part_id=part.id) }}" class="btn btn-primary">Edit Part</a>
            {% if origin == 'admin' %}
                <a href="{{ url_for('admin') }}" class="btn btn-secondary">Back to Admin</a>
            {% else %}
                <a href="{{ url_for('index') }}" class="btn btn-secondary">Back to List</a>
            {% endif %}
        </div>
    </div>
    <hr>
    <div class="row">
        <div class="col-md-6">
            {% if part.thumbnail %}
            <div class="mb-4 text-center">
                <img src="{{ url_for('uploaded_file', filename=part.thumbnail) }}" alt="Thumbnail for {{ part.part_number }}" class="img-fluid img-thumbnail" style="max-height: 250px;">
            </div>
            {% endif %}
            <h2>Information</h2>
            <table class="table">
                <tbody>
                    <tr>
                        <th scope="row">Part Number</th>
                        <td>{{ part['part_number'] }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Description</th>
                        <td>{{ part['description'] }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Barcode</th>
                        <td>{{ part['barcode'] }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Unit of Measure</th>
                        <td>{{ part['uom'] }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Supplier Name</th>
                        <td>{{ part['supplier_name'] }}</td>
                    </tr>

                    <tr>
                        <th scope="row">Part Type</th>
                        <td>{{ part['part_type'] }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Category</th>
                        <td>{{ part['category'] if part['category'] else 'N/A' }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Location</th>
                        <td>{{ part['location'] if part['location'] else 'N/A' }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Stock Quantity</th>
                        <td class="{% if part['reorder_level'] > 0 and part['stock_quantity'] <= part['reorder_level'] %}text-danger fw-bold{% endif %}">{{ part['stock_quantity'] }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Reorder Level</th>
                        <td>{{ part['reorder_level'] }}</td>
                    </tr>
                    <tr>
                        <th scope="row">Notes</th>
                        <td>{{ part['notes'] }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="col-md-6">

            {% if part['part_type'] in ['Manufactured', 'Assembly'] %}
            <h2>Bill of Materials</h2>
            {% if bom_components %}
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Component</th>
                            <th>Qty Required</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for comp in bom_components %}
                        <tr>
                            <td><a href="{{ url_for('admin_bp.part_view', part_id=comp['child_part_id']) }}">{{ comp['barcode'] }} - {{ comp['description'] }}</a></td>
                            <td>{{ comp['quantity_required'] }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <div class="card mt-3 mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Build Units</h5>
                        <form method="post" action="{{ url_for('admin_bp.build_part', part_id=part['id']) }}" class="row g-3 align-items-center">
                            <div class="col-auto">
                                <label for="build_quantity" class="visually-hidden">Quantity</label>
                                <input type="number" min="1" step="1" class="form-control" id="build_quantity" name="build_quantity" placeholder="Quantity to Build" required>
                            </div>
                            <div class="col-auto">
                                <button type="submit" class="btn btn-success">Build</button>
                            </div>
                        </form>
                    </div>
                </div>
            {% else %}
                <p>No BOM defined.</p>
            {% endif %}
            {% endif %}

            <h2>Photo Gallery</h2>
            {% if images %}
                <div class="row">
                    {% for image in images %}
                        <div class="col-md-4 mb-3">
                            <a href="#" class="thumbnail-link" data-bs-toggle="modal" data-bs-target="#imageModal" data-image-src="{{ url_for('uploaded_file', filename=image.filename) }}">
                                <img src="{{ url_for('uploaded_file', filename=image.filename) }}" class="img-thumbnail" alt="{{ image.filename }}">
                            </a>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p>No photos attached.</p>
            {% endif %}
        </div>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <img src="" id="modalImage" class="img-fluid" alt="Full size image">
                </div>
            </div>
        </div>
    </div>

    <hr>

    <h2>Attached Files</h2>
    {% if other_files %}
        <div class="row row-cols-1 row-cols-md-4 g-4 mb-4">
            {% for file in other_files %}
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body text-center d-flex flex-column justify-content-center">
                            <h5 class="card-title text-truncate mb-3" title="{{ file.filename }}">{{ file.filename }}</h5>
                            <a href="{{ url_for('uploaded_file', filename=file.filename) }}" class="btn btn-sm btn-outline-primary mt-auto" target="_blank">Download</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p>No files attached.</p>
    {% endif %}

    <hr>

    <h2>History / Audit Trail</h2>
    {% if audit_logs %}
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Timestamp</th>
                    <th>Action</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                {% for log in audit_logs %}
                    <tr>
                        <td>{{ log.timestamp }}</td>
                        <td>{{ log.action }}</td>
                        <td>{{ log.details }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>No history available.</p>
    {% endif %}
{% endblock %}
